<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">
    
    <changeSet id="2026-06-16--003-create-table-tasks.xml" author="gvayt">
        <createTable tableName="tasks">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="text" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="kid_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_tasks_kids" references="kids(id)"/>
            </column>
        </createTable>
    </changeSet>
    
</databaseChangeLog>